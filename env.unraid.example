# Copy to .env.unraid on your Unraid host.

# Use a long random value:
# openssl rand -base64 48
AUTH_SECRET=replace-with-long-random-secret

# Auth.js host trust + canonical URL (required)
AUTH_TRUST_HOST=true
AUTH_URL=http://192.168.1.11:3000

# Upstream providers (LAN URLs when self-hosting on another machine)
PIPED_BASE_URL=https://pipedapi.kavin.rocks
# PIPED_PROXY_BASE_URL=http://192.168.1.11:8092
# INVIDIOUS_BASE_URL=http://192.168.1.11:3210

# Browser-reachable OwnTube URL (LAN IP or reverse-proxy HTTPS URL)
# APP_BASE_URL=http://192.168.1.14:3000

# Process-wide upstream limiter (raise when self-hosting Piped + Invidious on LAN)
UPSTREAM_RATE_LIMIT_MAX_REQUESTS=300
UPSTREAM_RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info

# Optional timezone shown in logs
TZ=Europe/Paris
