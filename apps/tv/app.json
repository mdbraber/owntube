{
  "expo": {
    "name": "owntube TV",
    "slug": "owntube-tv",
    "version": "0.1.0",
    "orientation": "landscape",
    "userInterfaceStyle": "dark",
    "platforms": [
      "android"
    ],
    "android": {
      "package": "com.mdbraber.owntube.tv",
      "icon": "./assets/icon.png"
    },
    "plugins": [
      [
        "@react-native-tvos/config-tv",
        {
          "isTV": true,
          "androidTVBanner": "./assets/banner.png"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-speech-recognition",
      "./plugins/with-tv-search"
    ],
    "extra": {
      "owntubeUrl": "http://10.0.2.2:3000"
    },
    "icon": "./assets/icon.png",
    "scheme": "owntube"
  }
}
