# React Native / Metro assume a flat node_modules: transitive runtime deps like
# @babel/runtime must resolve from the top level. shamefully-hoist symlinks every
# dep (incl. transitive) up to node_modules/, which is where Metro looks. Scoped
# to this isolated TV install only — the web app keeps pnpm's default layout
# (hoisting broke its `sharp` native build).
shamefully-hoist=true
