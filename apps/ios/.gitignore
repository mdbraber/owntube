# Rust build output
src-tauri/target/

# Generated Xcode project build artifacts. The rest of src-tauri/gen/apple is
# committed: it holds the project file, entitlements and the generated icon set.
src-tauri/gen/apple/build/
src-tauri/gen/apple/Externals/
src-tauri/gen/apple/.tauri/
src-tauri/gen/apple/Pods/

.DS_Store

# Local, developer-specific configuration (server URL, signing team)
.env
src-tauri/capabilities/*.local.json

# Build-time generated capability/schema cache
src-tauri/gen/schemas/

# Generated Xcode project. project.yml is the tracked source; the .xcodeproj is
# regenerated by xcodegen at build time and Tauri writes the signing team into
# it, which must never be committed.
src-tauri/gen/apple/owntube.xcodeproj/
