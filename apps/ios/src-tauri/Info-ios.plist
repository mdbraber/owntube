<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Keep audio playing when the app is backgrounded or the screen is
         locked. Paired with the AVAudioSession(.playback) activation in native
         code; without both, iOS suspends WKWebView media on lock. -->
    <key>UIBackgroundModes</key>
    <array>
      <string>audio</string>
    </array>
    <!-- Register the owntube:// custom scheme so owntube://watch/<id> (produced
         by Privacy Redirect) opens the app. Handled in src/lib.rs, which
         rewrites it to the configured OwnTube server/<path>. -->
    <key>CFBundleURLTypes</key>
    <array>
      <dict>
        <key>CFBundleURLName</key>
        <string>com.mdbraber.owntube</string>
        <key>CFBundleURLSchemes</key>
        <array>
          <string>owntube</string>
        </array>
      </dict>
    </array>
  </dict>
</plist>
