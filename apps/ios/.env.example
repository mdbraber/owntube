# Copy to .env and fill in. Nothing here belongs in the repo.

# URL of the OwnTube web app the shell loads.
OWNTUBE_URL=http://localhost:3000

# Apple Developer Team ID used to sign the app. Find it in Xcode under
# Settings -> Accounts, or at https://developer.apple.com/account (Membership).
# Leave empty to pick a team manually in Xcode instead.
IOS_DEVELOPMENT_TEAM=
