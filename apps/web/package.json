{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted privacy-first YouTube frontend backed by Piped and Invidious. No Google APIs.",
  "license": "MIT",
  "homepage": "https://github.com/spookiss/owntube#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/spookiss/owntube.git"
  },
  "bugs": {
    "url": "https://github.com/spookiss/owntube/issues"
  },
  "keywords": [
    "youtube",
    "piped",
    "invidious",
    "self-hosted",
    "privacy",
    "nextjs",
    "trpc",
    "drizzle",
    "sqlite",
    "recommendations"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "warm:cache": "tsx scripts/warm-cache.ts",
    "warm:feed": "tsx scripts/warm-cache.ts",
    "export:icons": "tsx scripts/export-brand-icons.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-query": "^5.90.5",
    "@trpc/client": "^11.7.1",
    "@trpc/react-query": "^11.7.1",
    "@trpc/server": "^11.7.1",
    "@vidstack/react": "^0.6.15",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.7",
    "hls.js": "^1.6.16",
    "next": "15.5.15",
    "next-auth": "5.0.0-beta.31",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "superjson": "^2.2.5",
    "tailwind-merge": "^3.3.1",
    "vidstack": "0.6.15",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/to-ico": "^1.1.3",
    "@vitejs/plugin-react": "^5.1.0",
    "drizzle-kit": "^0.31.6",
    "jsdom": "^27.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "to-ico": "^1.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.3"
  }
}
