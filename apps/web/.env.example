# SQLite file (default: ./data/owntube.db)
DATABASE_PATH=./data/owntube.db

# Primary Piped API base (no trailing slash).
# Set to "disabled" to skip Piped entirely and use only Invidious.
# Public instances list: https://piped-instances.kavin.rocks/
PIPED_BASE_URL=https://pipedapi.kavin.rocks
# Piped media proxy (videoplayback / thumbnails) — often port 8092 when self-hosting
# PIPED_PROXY_BASE_URL=http://192.168.1.11:8092
# Force /piped-media relay (default: browser loads 8092 directly — better on LAN)
# PIPED_FORCE_MEDIA_RELAY=true

# Instance base URL the BROWSER can reach (defaults to INVIDIOUS_BASE_URL).
# Used to build companion-direct segment URLs when direct modes are on.
# INVIDIOUS_PUBLIC_BASE_URL=https://invidious.example.org

# DASH segments stream browser->companion directly by default (CORS *, one hop,
# never googlevideo). Set to false to force the same-origin /invidious proxy
# (e.g. when the instance host is not reachable from the browser).
# INVIDIOUS_DIRECT_DASH_SEGMENTS=true

# Same idea for the synthesized HLS path (default: proxied same-origin).
# INVIDIOUS_DIRECT_HLS_SEGMENTS=false

# Invidious fallback (no trailing slash).
# Set this to a reliable instance — or your own self-hosted one.
# Use `disabled` (or `disable`) to turn Invidious off and use Piped only.
# Self-hosting guide: docs/SELF-HOSTING.md
# Public instances list: https://api.invidious.io/
# INVIDIOUS_BASE_URL=https://your-invidious.example
# INVIDIOUS_BASE_URL=disabled

# ── Self-hosted Invidious (recommended for local dev) ─────────────────────────
# Run:  bash scripts/setup-invidious.sh
# Then uncomment:
# PIPED_BASE_URL=disabled
# INVIDIOUS_BASE_URL=http://localhost:3001

# debug | info | warn | error
LOG_LEVEL=info
# Process-wide upstream limiter (OwnTube side, not Invidious/Piped side)
# UPSTREAM_RATE_LIMIT_MAX_REQUESTS=60
# UPSTREAM_RATE_LIMIT_WINDOW_MS=60000

# Recommendation score debug: logs to stdout and logs/recommendation-debug.ndjson
# OWNTUBE_DEBUG_RECOMMENDATIONS=1
# Optional absolute or cwd-relative path:
# OWNTUBE_RECOMMENDATION_LOG_PATH=./logs/my-recs.ndjson

# Public URL you open in the browser (required on Docker/Unraid when Host is 0.0.0.0).
# APP_BASE_URL=http://192.168.1.14:3000

# Next.js (disable telemetry in containers)
NEXT_TELEMETRY_DISABLED=1

# Auth.js secret for JWT sessions
AUTH_SECRET=change-me-in-production

# ── Cache warmer (Docker sidecar) ─────────────────────────────────────────────
# OWNTUBE_WARM_INTERVAL_SEC=1200
# OWNTUBE_WARM_REGION=US
# OWNTUBE_WARM_LIMIT=48
# OWNTUBE_WARM_CHANNELS=true
# OWNTUBE_WARM_CHANNEL_PAGES=true
# OWNTUBE_WARM_SHORTS=true
# OWNTUBE_WARM_HISTORY_CHANNELS=32
# OWNTUBE_WARM_SUBSCRIPTION_CHANNELS=64
