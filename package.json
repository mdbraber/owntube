{
  "name": "owntube-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "OwnTube monorepo — privacy-first YouTube frontend (apps/web) and TV client (apps/tv).",
  "license": "MIT",
  "homepage": "https://github.com/spookiss/owntube#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/spookiss/owntube.git"
  },
  "bugs": {
    "url": "https://github.com/spookiss/owntube/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "biome check",
    "format": "biome format --write",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter web test",
    "test:watch": "pnpm --filter web test:watch",
    "test:e2e": "pnpm --filter web test:e2e",
    "db:migrate": "pnpm --filter web db:migrate",
    "db:generate": "pnpm --filter web db:generate",
    "db:studio": "pnpm --filter web db:studio",
    "warm:cache": "pnpm --filter web warm:cache",
    "export:icons": "pnpm --filter web export:icons"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0"
  }
}
